# Copy this file to `.env` in the project root and set your key.
# `.env` is gitignored; do not commit real secrets.
#
# Google AI Studio / Gemini (required for `python -m triage_langchain`):
GOOGLE_API_KEY=
# If you use this name instead, either works with langchain-google-genai:
# GEMINI_API_KEY=

# Optional: override the default model string (see `triage_langchain/workflow.py`)
# TRIAGE_LANGCHAIN_MODEL=google_genai:gemini-2.0-flash
